DISCORD_TOKEN=coloque_o_token_do_bot
DISCORD_CLIENT_ID=coloque_o_application_client_id
DISCORD_GUILD_ID=coloque_o_id_do_servidor_para_registro_instantaneo

MISTICPAY_CLIENT_ID=coloque_o_ci
MISTICPAY_CLIENT_SECRET=coloque_o_cs
MISTICPAY_BASE_URL=https://api.misticpay.com/api
MISTICPAY_DEFAULT_PAYER_NAME=Cliente Discord

# Opcional. O bot nao pede CPF no Discord. Preencha somente se a sua conta/API exigir
# documento padrao para criar cobrancas Pix.
MISTICPAY_DEFAULT_PAYER_DOCUMENT=

# Usuarios ou cargos autorizados a usar comandos financeiros.
# Separe varios IDs por virgula. Por seguranca, deixe pelo menos um preenchido.
AUTHORIZED_USER_IDS=
AUTHORIZED_ROLE_IDS=
ALLOW_DISCORD_ADMINS=false

# Se quiser enviar webhooks da MisticPay para este bot, publique a URL abaixo
# e use o endpoint /webhooks/misticpay.
MISTICPAY_PROJECT_WEBHOOK_URL=
WEBHOOK_SERVER_ENABLED=false
WEBHOOK_PORT=3000
WEBHOOK_SECRET=
DISCORD_WEBHOOK_CHANNEL_ID=

# Opcional: registra slash commands ao iniciar. Em producao prefira npm run deploy-commands.
AUTO_DEPLOY_COMMANDS=false
